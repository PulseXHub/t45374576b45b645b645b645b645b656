                        BackgroundTransparency = 1,
                        TextColor3 = Theme.TextDim,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Font = Enum.Font.Gotham,
                        TextSize = 11,
                        ZIndex = 4,
                    }, BtnFrame)
                end

                Btn.MouseEnter:Connect(function()
                    Tween(Btn, {BackgroundColor3 = Theme.ButtonHover}, 0.15)
                end)
                Btn.MouseLeave:Connect(function()
                    Tween(Btn, {BackgroundColor3 = Theme.Button}, 0.15)
                end)
                Btn.MouseButton1Click:Connect(function()
                    Tween(Btn, {BackgroundColor3 = Color3.fromRGB(80, 60, 180)}, 0.05)
                    task.delay(0.1, function()
                        Tween(Btn, {BackgroundColor3 = Theme.ButtonHover}, 0.1)
                    end)
                    callback()
                end)

                return Btn
            end

            -- =============================================
            -- TOGGLE
            -- =============================================
            function SectionObj:AddToggle(togConfig)
                togConfig = togConfig or {}
                local text     = togConfig.Text     or "Toggle"
                local default  = togConfig.Default  or false
                local callback = togConfig.Callback  or function() end
                local desc     = togConfig.Description

                local state = default

                local TogFrame = NewInst("Frame", {
                    Size = UDim2.new(1, 0, 0, desc and 52 or 36),
                    BackgroundColor3 = Theme.Button,
                    LayoutOrder = SNextOrder(),
                    ZIndex = 4,
                }, Section)
                AddCorner(TogFrame, 6)

                NewInst("TextLabel", {
                    Text = text,
                    Size = UDim2.new(1, -60, 1, 0),
                    Position = UDim2.new(0, 10, 0, 0),
                    BackgroundTransparency = 1,
                    TextColor3 = Theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    ZIndex = 5,
                }, TogFrame)

                if desc then
                    NewInst("TextLabel", {
                        Text = desc,
                        Size = UDim2.new(1, -60, 0, 16),
                        Position = UDim2.new(0, 10, 0, 32),
                        BackgroundTransparency = 1,
                        TextColor3 = Theme.TextDim,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Font = Enum.Font.Gotham,
                        TextSize = 11,
                        ZIndex = 5,
                    }, TogFrame)
                end

                -- Toggle switch background
                local SwitchBG = NewInst("Frame", {
                    Size = UDim2.new(0, 40, 0, 22),
                    Position = UDim2.new(1, -50, 0.5, -11),
                    BackgroundColor3 = state and Theme.Toggle_ON or Theme.Toggle_OFF,
                    BorderSizePixel = 0,
                    ZIndex = 5,
                }, TogFrame)
                AddCorner(SwitchBG, 11)

                local SwitchKnob = NewInst("Frame", {
                    Size = UDim2.new(0, 16, 0, 16),
                    Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    BorderSizePixel = 0,
                    ZIndex = 6,
                }, SwitchBG)
                AddCorner(SwitchKnob, 8)

                local function UpdateToggle()
                    Tween(SwitchBG, {BackgroundColor3 = state and Theme.Toggle_ON or Theme.Toggle_OFF}, 0.15)
                    Tween(SwitchKnob, {
                        Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
                    }, 0.15)
                end

                local TogBtn = NewInst("TextButton", {
                    Text = "",
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    ZIndex = 7,
                }, TogFrame)

                TogBtn.MouseButton1Click:Connect(function()
                    state = not state
                    UpdateToggle()
                    callback(state)
                end)

                TogFrame.MouseEnter:Connect(function()
                    Tween(TogFrame, {BackgroundColor3 = Color3.fromRGB(42,42,60)}, 0.1)
                end)
                TogFrame.MouseLeave:Connect(function()
                    Tween(TogFrame, {BackgroundColor3 = Theme.Button}, 0.1)
                end)

                UpdateToggle()

                local TogObj = {}
                function TogObj:Set(val)
                    state = val
                    UpdateToggle()
                    callback(state)
                end
                function TogObj:Get() return state end
                return TogObj
            end

            -- =============================================
            -- SLIDER
            -- =============================================
            function SectionObj:AddSlider(sliderConfig)
                sliderConfig = sliderConfig or {}
                local text     = sliderConfig.Text     or "Slider"
                local min      = sliderConfig.Min      or 0
                local max      = sliderConfig.Max      or 100
                local default  = sliderConfig.Default  or min
                local suffix   = sliderConfig.Suffix   or ""
                local callback = sliderConfig.Callback  or function() end

                local value = math.clamp(default, min, max)

                local SliderFrame = NewInst("Frame", {
                    Size = UDim2.new(1, 0, 0, 54),
                    BackgroundColor3 = Theme.Button,
                    LayoutOrder = SNextOrder(),
                    ZIndex = 4,
                }, Section)
                AddCorner(SliderFrame, 6)

                local HeaderRow = NewInst("Frame", {
                    Size = UDim2.new(1, 0, 0, 24),
                    Position = UDim2.new(0, 0, 0, 6),
                    BackgroundTransparency = 1,
                    ZIndex = 5,
                }, SliderFrame)

                NewInst("TextLabel", {
                    Text = text,
                    Size = UDim2.new(0.7, 0, 1, 0),
                    Position = UDim2.new(0, 10, 0, 0),
                    BackgroundTransparency = 1,
                    TextColor3 = Theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    ZIndex = 5,
                }, HeaderRow)

                local ValueLabel = NewInst("TextLabel", {
                    Text = tostring(value)..suffix,
                    Size = UDim2.new(0.3, -10, 1, 0),
                    Position = UDim2.new(0.7, 0, 0, 0),
                    BackgroundTransparency = 1,
                    TextColor3 = Theme.Accent,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Font = Enum.Font.GothamBold,
                    TextSize = 13,
                    ZIndex = 5,
                }, HeaderRow)

                local TrackBG = NewInst("Frame", {
                    Size = UDim2.new(1, -20, 0, 6),
                    Position = UDim2.new(0, 10, 0, 36),
                    BackgroundColor3 = Theme.SliderBG,
                    BorderSizePixel = 0,
                    ZIndex = 5,
                }, SliderFrame)
                AddCorner(TrackBG, 3)

                local Fill = NewInst("Frame", {
                    Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                    BackgroundColor3 = Theme.Slider,
                    BorderSizePixel = 0,
                    ZIndex = 6,
                }, TrackBG)
                AddCorner(Fill, 3)

                local Knob = NewInst("Frame", {
                    Size = UDim2.new(0, 14, 0, 14),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    BorderSizePixel = 0,
                    ZIndex = 7,
                }, TrackBG)
                AddCorner(Knob, 7)

                local draggingSlider = false

                local function UpdateSlider(x)
                    local absX = TrackBG.AbsolutePosition.X
                    local absW = TrackBG.AbsoluteSize.X
                    local pct = math.clamp((x - absX) / absW, 0, 1)
                    value = math.floor(min + (max - min) * pct)
                    ValueLabel.Text = tostring(value)..suffix
                    Tween(Fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.05)
                    Tween(Knob, {Position = UDim2.new(pct, 0, 0.5, 0)}, 0.05)
                    callback(value)
                end

                TrackBG.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = true
                        UpdateSlider(input.Position.X)
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
                        UpdateSlider(input.Position.X)
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = false
                    end
                end)

                local SliderObj = {}
                function SliderObj:Set(val)
                    value = math.clamp(val, min, max)
                    local pct = (value - min) / (max - min)
                    ValueLabel.Text = tostring(value)..suffix
                    Fill.Size = UDim2.new(pct, 0, 1, 0)
                    Knob.Position = UDim2.new(pct, 0, 0.5, 0)
                    callback(value)
                end
                function SliderObj:Get() return value end
                return SliderObj
            end

            -- =============================================
            -- DROPDOWN
            -- =============================================
            function SectionObj:AddDropdown(ddConfig)
                ddConfig = ddConfig or {}
                local text     = ddConfig.Text     or "Dropdown"
                local options  = ddConfig.Options   or {}
                local default  = ddConfig.Default   or options[1]
                local callback = ddConfig.Callback   or function() end

                local selected = default
                local isOpen = false

                local DDFrame = NewInst("Frame", {
                    Size = UDim2.new(1, 0, 0, 36),
                    BackgroundColor3 = Theme.Button,
                    LayoutOrder = SNextOrder(),
                    ClipsDescendants = false,
                    ZIndex = 8,
                }, Section)
                AddCorner(DDFrame, 6)

                NewInst("TextLabel", {
                    Text = text,
                    Size = UDim2.new(0.5, 0, 1, 0),
                    Position = UDim2.new(0, 10, 0, 0),
                    BackgroundTransparency = 1,
                    TextColor3 = Theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    ZIndex = 9,
                }, DDFrame)

                local SelLabel = NewInst("TextLabel", {
                    Text = tostring(selected or "Select..."),
                    Size = UDim2.new(0.5, -40, 1, 0),
                    Position = UDim2.new(0.5, 0, 0, 0),
                    BackgroundTransparency = 1,
                    TextColor3 = Theme.Accent,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    ZIndex = 9,
                }, DDFrame)

                local ArrowLabel = NewInst("TextLabel", {
                    Text = "▾",
                    Size = UDim2.new(0, 24, 1, 0),
                    Position = UDim2.new(1, -28, 0, 0),
                    BackgroundTransparency = 1,
                    TextColor3 = Theme.TextDim,
                    Font = Enum.Font.GothamBold,
                    TextSize = 14,
                    ZIndex = 9,
                }, DDFrame)

                -- Dropdown list
                local DDList = NewInst("Frame", {
                    Size = UDim2.new(1, 0, 0, 0),
                    Position = UDim2.new(0, 0, 1, 4),
                    BackgroundColor3 = Theme.Dropdown,
                    BorderSizePixel = 0,
                    ClipsDescendants = true,
                    Visible = false,
                    ZIndex = 20,
                }, DDFrame)
                AddCorner(DDList, 6)
                AddStroke(DDList, Theme.Border, 1)

                NewInst("UIListLayout", {
                    Padding = UDim.new(0, 2),
                    FillDirection = Enum.FillDirection.Vertical,
                    SortOrder = Enum.SortOrder.LayoutOrder,
                }, DDList)
                AddPadding(DDList, 4, 4, 4, 4)

                for i, opt in ipairs(options) do
                    local Item = NewInst("TextButton", {
                        Text = tostring(opt),
                        Size = UDim2.new(1, 0, 0, 28),
                        BackgroundColor3 = Theme.DropdownItem,
                        TextColor3 = Theme.Text,
                        Font = Enum.Font.Gotham,
                        TextSize = 12,
                        BorderSizePixel = 0,
                        LayoutOrder = i,
                        ZIndex = 21,
                        TextXAlignment = Enum.TextXAlignment.Left,
                    }, DDList)
                    AddCorner(Item, 4)
                    AddPadding(Item, 0, 0, 8, 0)

                    Item.MouseEnter:Connect(function()
                        Tween(Item, {BackgroundColor3 = Theme.TabSelected}, 0.1)
                    end)
                    Item.MouseLeave:Connect(function()
                        Tween(Item, {BackgroundColor3 = Theme.DropdownItem}, 0.1)
                    end)
                    Item.MouseButton1Click:Connect(function()
                        selected = opt
                        SelLabel.Text = tostring(opt)
                        callback(opt)
                        isOpen = false
                        DDList.Visible = false
                        Tween(ArrowLabel, {Rotation = 0}, 0.15)
                    end)
                end

                local listHeight = #options * 30 + 8
                DDList.Size = UDim2.new(1, 0, 0, 0)

                local DDBtn = NewInst("TextButton", {
                    Text = "",
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    ZIndex = 10,
                }, DDFrame)

                DDBtn.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    DDList.Visible = isOpen
                    if isOpen then
                        Tween(DDList, {Size = UDim2.new(1, 0, 0, listHeight)}, 0.2)
                        Tween(ArrowLabel, {Rotation = 180}, 0.15)
                    else
                        Tween(DDList, {Size = UDim2.new(1, 0, 0, 0)}, 0.15)
                        Tween(ArrowLabel, {Rotation = 0}, 0.15)
                    end
                end)

                local DDObj = {}
                function DDObj:Set(val)
                    selected = val
                    SelLabel.Text = tostring(val)
                    callback(val)
                end
                function DDObj:Get() return selected end
                return DDObj
            end

            -- =============================================
            -- TEXTBOX
            -- =============================================
            function SectionObj:AddTextBox(tbConfig)
                tbConfig = tbConfig or {}
                local text       = tbConfig.Text        or "TextBox"
                local placeholder = tbConfig.Placeholder or "Enter text..."
                local callback   = tbConfig.Callback     or function() end
                local clearOnFocus = tbConfig.ClearOnFocus

                if clearOnFocus == nil then clearOnFocus = true end

                local TBFrame = NewInst("Frame", {
                    Size = UDim2.new(1, 0, 0, 56),
                    BackgroundTransparency = 1,
                    LayoutOrder = SNextOrder(),
                    ZIndex = 4,
                }, Section)

                NewInst("TextLabel", {
                    Text = text,
                    Size = UDim2.new(1, -10, 0, 22),
                    Position = UDim2.new(0, 10, 0, 0),
                    BackgroundTransparency = 1,
                    TextColor3 = Theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    ZIndex = 5,
                }, TBFrame)

                local TB = NewInst("TextBox", {
                    PlaceholderText = placeholder,
                    Text = "",
                    Size = UDim2.new(1, 0, 0, 30),
                    Position = UDim2.new(0, 0, 0, 24),
                    BackgroundColor3 = Theme.TextBox,
                    TextColor3 = Theme.Text,
                    PlaceholderColor3 = Theme.TextDim,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    BorderSizePixel = 0,
                    ClearTextOnFocus = clearOnFocus,
                    ZIndex = 5,
                    TextXAlignment = Enum.TextXAlignment.Left,
                }, TBFrame)
                AddCorner(TB, 6)
                AddStroke(TB, Theme.Border, 1)
                AddPadding(TB, 0, 0, 8, 0)

                TB.FocusLost:Connect(function(enterPressed)
                    if enterPressed then
                        callback(TB.Text)
                    end
                end)

                return TB
            end

            -- =============================================
            -- LABEL
            -- =============================================
            function SectionObj:AddLabel(labelText)
                local Lbl = NewInst("TextLabel", {
                    Text = labelText or "",
                    Size = UDim2.new(1, 0, 0, 28),
                    BackgroundTransparency = 1,
                    TextColor3 = Theme.TextDim,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    LayoutOrder = SNextOrder(),
                    ZIndex = 4,
                }, Section)
                AddPadding(Lbl, 0, 0, 10, 0)
                return Lbl
            end

            -- =============================================
            -- SEPARATOR
            -- =============================================
            function SectionObj:AddSeparator()
                NewInst("Frame", {
                    Size = UDim2.new(1, -16, 0, 1),
                    BackgroundColor3 = Theme.Border,
                    BorderSizePixel = 0,
                    LayoutOrder = SNextOrder(),
                    ZIndex = 4,
                }, Section)
            end

            return SectionObj
        end -- CreateSection

        return Tab
    end -- CreateTab

    -- =============================================
    -- NOTIFICATION
    -- =============================================
    function Window:Notify(notifConfig)
        notifConfig = notifConfig or {}
        local title    = notifConfig.Title    or "Notification"
        local message  = notifConfig.Message  or ""
        local duration = notifConfig.Duration  or 4

        local NotifBox = NewInst("Frame", {
            Name = "Notif",
            Size = UDim2.new(1, 0, 0, 70),
            BackgroundColor3 = Theme.Notification,
            BorderSizePixel = 0,
            BackgroundTransparency = 1,
            ZIndex = 15,
        }, self._notifFrame)
        AddCorner(NotifBox, 8)
        AddStroke(NotifBox, Theme.Accent, 1.5)

        -- Left accent bar
        NewInst("Frame", {
            Size = UDim2.new(0, 3, 0, 40),
            Position = UDim2.new(0, 0, 0.5, -20),
            BackgroundColor3 = Theme.Accent,
            BorderSizePixel = 0,
            ZIndex = 16,
        }, NotifBox)

        NewInst("TextLabel", {
            Text = title,
            Size = UDim2.new(1, -20, 0, 26),
            Position = UDim2.new(0, 14, 0, 8),
            BackgroundTransparency = 1,
            TextColor3 = Theme.Text,
            TextXAlignment = Enum.TextXAlignment.Left,
            Font = Enum.Font.GothamBold,
            TextSize = 14,
            ZIndex = 16,
        }, NotifBox)

        NewInst("TextLabel", {
            Text = message,
            Size = UDim2.new(1, -20, 0, 22),
            Position = UDim2.new(0, 14, 0, 34),
            BackgroundTransparency = 1,
            TextColor3 = Theme.TextDim,
            TextXAlignment = Enum.TextXAlignment.Left,
            Font = Enum.Font.Gotham,
            TextSize = 12,
            ZIndex = 16,
            TextWrapped = true,
        }, NotifBox)

        Tween(NotifBox, {BackgroundTransparency = 0}, 0.3)

        task.delay(duration, function()
            Tween(NotifBox, {BackgroundTransparency = 1}, 0.3)
            task.delay(0.35, function()
                NotifBox:Destroy()
            end)
        end)
    end

    -- =============================================
    -- TOGGLE GUI VISIBILITY (Keybind)
    -- =============================================
    function Window:SetToggleKey(key)
        UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if input.KeyCode == key then
                Main.Visible = not Main.Visible
            end
        end)
    end

    return Window
end

return NexusHub
