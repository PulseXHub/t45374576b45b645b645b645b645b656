    -- =============================================
    -- CREATE TAB
    -- =============================================
    function Window:CreateTab(name, icon)
        local tabIndex = #self._tabs + 1

        -- Tab Button
        local TabBtn = NewInst("TextButton", {
            Name = "Tab_"..name,
            Text = (icon and icon.." " or "") .. name,
            Size = UDim2.new(1, 0, 0, 34),
            BackgroundColor3 = Theme.Tab,
            TextColor3 = Theme.TextDim,
            Font = Enum.Font.Gotham,
            TextSize = 13,
            BorderSizePixel = 0,
            LayoutOrder = tabIndex,
            ZIndex = 3,
            TextXAlignment = Enum.TextXAlignment.Left,
        }, TabBar)
        AddCorner(TabBtn, 6)
        AddPadding(TabBtn, 0, 0, 10, 0)

        -- Tab Content Frame
        local TabContent = NewInst("ScrollingFrame", {
            Name = "Content_"..name,
            Size = UDim2.new(1, 0, 1, 0),
            Position = UDim2.new(0,0,0,0),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = Theme.Accent,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Visible = false,
            ZIndex = 2,
        }, ContentHolder)

        NewInst("UIListLayout", {
            Padding = UDim.new(0, 8),
            FillDirection = Enum.FillDirection.Vertical,
            HorizontalAlignment = Enum.HorizontalAlignment.Center,
            SortOrder = Enum.SortOrder.LayoutOrder,
        }, TabContent)
        AddPadding(TabContent, 10, 10, 10, 10)

        table.insert(self._tabs, name)
        self._tabButtons[name] = TabBtn
        self._tabContents[name] = TabContent

        local function SelectTab()
            for _, btn in pairs(self._tabButtons) do
                Tween(btn, {BackgroundColor3 = Theme.Tab}, 0.15)
                btn.TextColor3 = Theme.TextDim
            end
            for _, content in pairs(self._tabContents) do
                content.Visible = false
            end
            Tween(TabBtn, {BackgroundColor3 = Theme.TabSelected}, 0.15)
            TabBtn.TextColor3 = Theme.Text
            TabContent.Visible = true
            self._activeTab = name
        end

        TabBtn.MouseButton1Click:Connect(SelectTab)

        TabBtn.MouseEnter:Connect(function()
            if self._activeTab ~= name then
                Tween(TabBtn, {BackgroundColor3 = Color3.fromRGB(42, 42, 60)}, 0.1)
            end
        end)
        TabBtn.MouseLeave:Connect(function()
            if self._activeTab ~= name then
                Tween(TabBtn, {BackgroundColor3 = Theme.Tab}, 0.1)
            end
        end)

        -- Auto-select first tab
        if tabIndex == 1 then
            SelectTab()
        end

        -- Section / Element API
        local Tab = {}
        Tab._content = TabContent
        Tab._layoutOrder = 0

        local function NextOrder()
            Tab._layoutOrder += 1
            return Tab._layoutOrder
        end

        -- =============================================
        -- CREATE SECTION
        -- =============================================
        function Tab:CreateSection(sectionName)
            local Section = NewInst("Frame", {
                Name = "Section_"..sectionName,
                Size = UDim2.new(1, -16, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundColor3 = Theme.Section,
                BorderSizePixel = 0,
                LayoutOrder = NextOrder(),
                ZIndex = 3,
            }, TabContent)
            AddCorner(Section, 8)
            AddStroke(Section, Theme.Border, 1)

            NewInst("UIListLayout", {
                Padding = UDim.new(0, 6),
                FillDirection = Enum.FillDirection.Vertical,
                HorizontalAlignment = Enum.HorizontalAlignment.Center,
                SortOrder = Enum.SortOrder.LayoutOrder,
            }, Section)

            -- Section Header
            local Header = NewInst("Frame", {
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundColor3 = Color3.fromRGB(28, 28, 42),
                BorderSizePixel = 0,
                LayoutOrder = 0,
                ZIndex = 4,
            }, Section)
            AddCorner(Header, 7)

            -- Accent left bar
            NewInst("Frame", {
                Size = UDim2.new(0, 3, 0, 16),
                Position = UDim2.new(0, 10, 0.5, -8),
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel = 0,
                ZIndex = 5,
            }, Header)

            NewInst("TextLabel", {
                Text = sectionName,
                Size = UDim2.new(1, -30, 1, 0),
                Position = UDim2.new(0, 20, 0, 0),
                BackgroundTransparency = 1,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                Font = Enum.Font.GothamSemibold,
                TextSize = 13,
                ZIndex = 5,
            }, Header)

            AddPadding(Section, 0, 8, 8, 8)

            local SectionObj = {}
            SectionObj._section = Section
            SectionObj._layoutOrder = 1

            local function SNextOrder()
                SectionObj._layoutOrder += 1
                return SectionObj._layoutOrder
